# pipir web LLM configuration — copy to .env (gitignored) and fill in.
# Any OpenAI-compatible chat-completions endpoint works (org-internal
# gateways, OpenAI, Anthropic compat, Ollama, vLLM, llama.cpp ...).

# Base URL up to but not including /chat/completions
PIPIR_LLM_BASE_URL=https://llm.internal.example.com/v1

# Bearer token; leave empty for unauthenticated endpoints
PIPIR_LLM_API_KEY=

# Model name to request
PIPIR_LLM_MODEL=gpt-4o
